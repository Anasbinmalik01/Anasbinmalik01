VERIFY RECEIPT LOGIC
Create:
js/verify.js

import { db } from "./firebase.js";
import { collection, query, where, getDocs } 
from "https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js";

const verifyBtn = document.getElementById("verifyBtn");

verifyBtn.addEventListener("click", async () => {

  const code = document.getElementById("receiptCodeInput").value;

  const q = query(
    collection(db, "receipts"),
    where("receiptCode", "==", code)
  );

  const querySnapshot = await getDocs(q);

  const resultDiv = document.getElementById("result");

  if (querySnapshot.empty) {
    resultDiv.innerHTML = "<h3 style='color:red;'>x Invalid Receipt</h3>";
  } else {
    querySnapshot.forEach((doc) => {
      const data = doc.data();

      resultDiv.innerHTML = `
        <h3 style="color:green;">✓ Verified Receipt</h3>
        <p><strong>Business:</strong> ${data.businessName}</p>
        <p><strong>Customer:</strong> ${data.customerName}</p>
        <p><strong>Item:</strong> ${data.itemDescription}</p>
        <p><strong>Amount:</strong> ₦${data.amount}</p>
      `;
    });
  }
});

