FIRESTORE SECURITY RULES
Go to Firestore → Rules → Replace with:

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // USERS COLLECTION
    match /users/{userId} {
      allow read, write: if request.auth != null 
                         && request.auth.uid == userId;
    }

    // RECEIPTS COLLECTION
    match /receipts/{receiptId} {

      // Merchant can create receipt
      allow create: if request.auth != null;

      // Merchant can read their own receipts
      allow read: if request.auth != null 
                  && request.auth.uid == resource.data.merchantId;

      // Public verification allowed ONLY for receiptCode queries
      allow list: if true;

      allow get: if true;
    }
  }
}

RECEIPT CODE GENERATOR
Create function inside:
js/receipt.js

function generateReceiptCode() {
  const randomNumber = Math.floor(10000 + Math.random() * 90000);
  return "TPL-" + randomNumber;
}

CREATE RECEIPT LOGIC
Inside js/receipt.js:

import { db, auth } from "./firebase.js";
import { collection, addDoc, serverTimestamp } 
from "https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js";

const form = document.getElementById("receiptForm");

form.addEventListener("submit", async (e) => {
  e.preventDefault();

  const user = auth.currentUser;

  if (!user) {
    alert("Not logged in");
    return;
  }

  const customerName = document.getElementById("customerName").value;
  const itemDescription = document.getElementById("itemDescription").value;
  const amount = parseFloat(document.getElementById("amount").value);

  const receiptCode = generateReceiptCode();

  try {
    await addDoc(collection(db, "receipts"), {
      merchantId: user.uid,
      businessName: user.displayName || "Merchant",
      customerName,
      itemDescription,
      amount,
      receiptCode,
      date: new Date(),
      createdAt: serverTimestamp()
    });

    alert("Receipt Created Successfully!");
    window.location.href = "dashboard.html";

  } catch (error) {
    console.error(error);
    alert("Error creating receipt");
  }
});

FETCH RECEIPTS (DASHBOARD)
Create:
js/dashboard.js

import { db, auth } from "./firebase.js";
import { collection, query, where, getDocs } 
from "https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js";

auth.onAuthStateChanged(async (user) => {
  if (!user) {
    window.location.href = "login.html";
    return;
  }

  const q = query(
    collection(db, "receipts"),
    where("merchantId", "==", user.uid)
  );

  const querySnapshot = await getDocs(q);

  const tableBody = document.getElementById("receiptTableBody");

  querySnapshot.forEach((doc) => {
    const data = doc.data();

    const row = `
      <tr>
        <td>${data.receiptCode}</td>
        <td>${data.customerName}</td>
        <td>₦${data.amount}</td>
        <td>${new Date(data.date.seconds * 1000).toLocaleDateString()}</td>
      </tr>
    `;

    tableBody.innerHTML += row;
  });
});

